    "# ── 5.1 Reweighing ─────────────────────────────────────────────────\n",
    "n_tr    = len(df_train)\n",
    "p_gender = df_train[\"gender\"].value_counts() / n_tr\n",
    "p_title  = df_train[\"title\"].value_counts()  / n_tr\n",
    "p_joint  = df_train.groupby([\"gender\", \"title\"]).size() / n_tr\n",

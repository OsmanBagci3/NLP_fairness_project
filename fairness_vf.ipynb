    "# ── Résultats globaux ─────────────────────────────────────────────────\n",
    "acc_train    = accuracy_score(y_train, y_pred_train)\n",
    "acc_val      = accuracy_score(y_val,   y_pred_val)\n",
    "f1_macro     = f1_score(y_val, y_pred_val, average=\"macro\")\n",
    "recall_macro = recall_score(y_val, y_pred_val, average=\"macro\")\n",
